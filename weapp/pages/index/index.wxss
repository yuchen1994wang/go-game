.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #F5F0E8 0%, #E8E0D5 100%);
  padding: 40rpx;
}

.header {
  padding: 40rpx 0;
  display: flex;
  justify-content: center;
}

.logo {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}

.logo-icon {
  width: 120rpx;
  height: 120rpx;
  position: relative;
}

.logo-icon .stone {
  position: absolute;
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
}

.logo-icon .stone.black {
  background: radial-gradient(circle at 30% 30%, #4a4a4a, #1a1a1a);
  box-shadow: 4rpx 4rpx 8rpx rgba(0,0,0,0.3);
  top: 10rpx;
  left: 10rpx;
}

.logo-icon .stone.white {
  background: radial-gradient(circle at 30% 30%, #ffffff, #f5f5f5);
  border: 2rpx solid #e0e0e0;
  box-shadow: 4rpx 4rpx 8rpx rgba(0,0,0,0.2);
  bottom: 10rpx;
  right: 10rpx;
}

.title {
  font-size: 48rpx;
  font-weight: 600;
  color: #2C1810;
  font-family: serif;
  letter-spacing: 8rpx;
}

.content {
  margin-top: 60rpx;
}

.welcome-card {
  background: rgba(255,252,245,0.9);
  border-radius: 24rpx;
  padding: 40rpx;
  text-align: center;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.08);
  margin-bottom: 40rpx;
}

.welcome-title {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #2C1810;
  margin-bottom: 16rpx;
}

.welcome-desc {
  display: block;
  font-size: 28rpx;
  color: #666;
}

.game-modes {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin-bottom: 40rpx;
}

.mode-card {
  background: rgba(255,252,245,0.95);
  border-radius: 20rpx;
  padding: 36rpx 40rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
  border: 2rpx solid transparent;
  transition: all 0.2s ease;
}

.mode-card:active {
  transform: scale(0.98);
  border-color: #B8860B;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
}

.mode-name {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #2C1810;
  margin-bottom: 8rpx;
}

.mode-desc {
  display: block;
  font-size: 26rpx;
  color: #888;
}

.features {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 24rpx;
}

.feature-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: rgba(255,252,245,0.8);
  padding: 16rpx 24rpx;
  border-radius: 40rpx;
}

.feature-icon {
  font-size: 28rpx;
}

.feature-text {
  font-size: 24rpx;
  color: #666;
}
