{
  "env": {
    "browser": true,
    "es2021": true,
    "node": true,
    "jest": true
  },
  "extends": "eslint:recommended",
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "plugins": ["html"],
  "rules": {
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    "no-console": ["warn", { "allow": ["error", "warn", "log"] }],
    "no-debugger": "error",
    "eqeqeq": ["error", "always"],
    "curly": ["error", "all"],
    "no-var": "error",
    "prefer-const": "error",
    "no-throw-literal": "error",
    "no-undef": "error"
  },
  "globals": {
    "GoEngine": "readonly",
    "GoGame": "readonly",
    "GoAI": "readonly",
    "AIAnalyzer": "readonly",
    "Storage": "readonly",
    "Header": "readonly",
    "showToast": "readonly",
    "debounce": "readonly",
    "showErrorBoundary": "readonly"
  },
  "ignorePatterns": [
    "node_modules/",
    "coverage/",
    "playwright-report/",
    "weapp/"
  ]
}
