{
  "env": {
    "browser": true,
    "es2021": true,
    "node": true,
    "jest": true
  },
  "extends": "eslint:recommended",
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "plugins": ["html"],
  "rules": {
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    "no-console": ["warn", { "allow": ["error", "warn", "log"] }],
    "no-debugger": "error",
    "eqeqeq": ["error", "always"],
    "curly": ["warn", "all"],
    "no-var": "error",
    "prefer-const": "warn",
    "no-throw-literal": "error",
    "no-undef": ["warn"]
  },
  "globals": {
    "GoEngine": "readonly",
    "GoGame": "readonly",
    "GoAI": "readonly",
    "AIAnalyzer": "readonly",
    "Storage": "readonly",
    "Header": "readonly",
    "showToast": "readonly",
    "debounce": "readonly",
    "showErrorBoundary": "readonly",
    "BoardComponent": "readonly",
    "TsumegoData": "readonly",
    "TsumegoStorage": "readonly",
    "TsumegoStats": "readonly",
    "StatisticsPanel": "readonly",
    "GameStats": "readonly",
    "PracticeStats": "readonly",
    "GrowthChart": "readonly",
    "RadarChart": "readonly",
    "LearningPath": "readonly",
    "PatternStudyUI": "readonly",
    "TimeFilter": "readonly",
    "MemoryManager": "readonly",
    "CanvasOptimizer": "readonly"
  },
  "ignorePatterns": [
    "node_modules/",
    "coverage/",
    "playwright-report/",
    "weapp/",
    "react-example/"
  ]
}
